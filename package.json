{
  "name": "selam-english",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.api.json",
    "test": "vitest run",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap add android && npx cap sync android",
    "cap:ios": "npm run build && npx cap add ios && npx cap sync ios"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@capacitor/local-notifications": "^7.0.2",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-sans-ethiopic": "^5.2.7",
    "@google/genai": "^1.32.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.58.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.10"
  }
}
